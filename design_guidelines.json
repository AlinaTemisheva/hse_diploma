{
  "identity": {
    "persona": "E1",
    "tone": "Academic, Professional, Clean, Trustworthy",
    "theme": "light",
    "principles": [
      "Clarity over decoration",
      "Academic rigor meets digital ease",
      "Whitespace is active space",
      "Blue is the color of trust"
    ]
  },
  "typography": {
    "font_family": {
      "headings": "Manrope, sans-serif",
      "body": "Inter, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "scale": {
      "h1": "text-4xl md:text-5xl font-bold tracking-tight",
      "h2": "text-3xl font-semibold tracking-tight",
      "h3": "text-2xl font-semibold",
      "h4": "text-xl font-medium",
      "body_lg": "text-lg leading-relaxed",
      "body_base": "text-base leading-relaxed text-gray-600",
      "caption": "text-sm text-gray-500",
      "small": "text-xs font-medium uppercase tracking-wider text-gray-400"
    }
  },
  "colors": {
    "palette": {
      "primary": {
        "DEFAULT": "#1B318E",
        "foreground": "#FFFFFF",
        "50": "#EEF2FF",
        "100": "#E0E7FF",
        "200": "#C7D2FE",
        "300": "#A5B4FC",
        "400": "#818CF8",
        "500": "#6366F1",
        "600": "#4F46E5",
        "700": "#1B318E",
        "800": "#3730A3",
        "900": "#312E81"
      },
      "background": {
        "DEFAULT": "#F5F7FA",
        "paper": "#FFFFFF"
      },
      "text": {
        "primary": "#111827",
        "secondary": "#6B7280",
        "tertiary": "#9CA3AF"
      },
      "accent": {
        "teal": "#14B8A6",
        "rose": "#F43F5E",
        "amber": "#F59E0B"
      },
      "border": "#E5E7EB"
    },
    "usage": {
      "primary_button": "bg-[#1B318E] hover:bg-[#1B318E]/90 text-white shadow-md",
      "secondary_button": "bg-white border border-gray-200 text-gray-700 hover:bg-gray-50",
      "active_tab": "bg-[#1B318E] text-white shadow-sm",
      "inactive_tab": "bg-transparent text-gray-500 hover:text-gray-900"
    }
  },
  "components": {
    "buttons": {
      "default": "rounded-lg font-medium transition-all duration-200 active:scale-95",
      "primary": "bg-[#1B318E] text-white hover:bg-[#2A42A5]",
      "ghost": "hover:bg-gray-100 text-gray-600"
    },
    "cards": {
      "default": "bg-white rounded-xl border border-gray-100 shadow-[0_2px_8px_rgba(0,0,0,0.04)] hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)] transition-shadow duration-300",
      "hover_effect": "hover:-translate-y-1 transition-transform duration-300"
    },
    "inputs": {
      "default": "rounded-lg border-gray-200 focus:border-[#1B318E] focus:ring-2 focus:ring-[#1B318E]/20 bg-white"
    },
    "tabs": {
      "container": "bg-gray-100/50 p-1 rounded-xl",
      "trigger": "rounded-lg px-4 py-2 text-sm font-medium transition-all data-[state=active]:bg-white data-[state=active]:text-[#1B318E] data-[state=active]:shadow-sm"
    }
  },
  "layout_strategies": {
    "login_page": {
      "structure": "grid grid-cols-1 lg:grid-cols-2 h-screen w-full overflow-hidden",
      "left_panel": "flex flex-col justify-center items-center p-8 lg:p-16 bg-white",
      "right_panel": "hidden lg:block bg-gray-50 relative"
    },
    "dashboard": {
      "wrapper": "min-h-screen bg-[#F5F7FA]",
      "container": "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8",
      "header": "sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200 h-16 flex items-center justify-between px-6",
      "grid": "grid grid-cols-1 md:grid-cols-12 gap-6"
    }
  },
