  "instructions_to_main_agent": [
    "1. THEME: Force LIGHT MODE. Do not implement dark mode toggle as this is an academic dashboard.",
    "2. COLORS: Update tailwind.config.js to use #1B318E as primary color. Ensure backgrounds are #F5F7FA.",
    "3. FONTS: Import Manrope for headings and Inter for body from Google Fonts.",
    "4. COMPONENTS: Use Shadcn components (Card, Tabs, Button, Input, Checkbox) but customized with the E1 guidelines.",
    "5. LAYOUT: Strict adherence to the provided screenshots. Login page must have the carousel on the right (desktop). Dashboard must have the 'Services' section as a horizontal scrollable row.",
    "6. MICRO-INTERACTIONS: Add hover states to service cards (lift up + shadow). Add smooth transitions to tab switching.",
    "7. DATA: Use mock data for tasks, courses, and documents to make the dashboard feel populated.",
    "8. ACCESSIBILITY: Ensure all text over images has proper contrast or scrims. All interactive elements must have aria-labels.",
    "9. TESTID: Add data-testid to all interactive elements (buttons, inputs, tabs) for testing."
  ],
  "universal_guidelines": [
    "Avoid generic centered layouts.",
    "Use glass-morphism effects for the sticky header.",
    "Never use generic AI emojis.",
    "Ensure 2-3x more spacing than typical designs.",
    "Use 'sonner' for toasts.",
    "Components must use named exports."
  ]
}